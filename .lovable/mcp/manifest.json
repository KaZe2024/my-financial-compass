{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://ywfvpkvavejieuxrijam.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "personal-cfo-mcp",
      "version": "0.1.0",
      "title": "Personal CFO"
    },
    "tools": [
      {
        "name": "get_financial_snapshot",
        "title": "Get financial snapshot",
        "description": "Retourne un instantané financier complet du foyer (patrimoine net, revenus, dépenses, portefeuilles, dettes, objectifs, provisions, projets) en Markdown, devise de référence MGA.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_wallets",
        "title": "List wallets",
        "description": "Liste tous les portefeuilles de l'utilisateur avec leur solde courant et devise.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_transactions",
        "title": "List transactions",
        "description": "Liste les transactions de l'utilisateur, avec filtres optionnels par date, type et portefeuille. Triées par date décroissante.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "from": {
              "description": "Date de début ISO (YYYY-MM-DD)",
              "type": "string"
            },
            "to": {
              "description": "Date de fin ISO (YYYY-MM-DD)",
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "income",
                "expense",
                "transfer"
              ]
            },
            "wallet_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "limit": {
              "default": 100,
              "type": "integer",
              "minimum": 1,
              "maximum": 500
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "create_transaction",
        "title": "Create transaction",
        "description": "Crée une nouvelle transaction (revenu, dépense ou transfert) dans le portefeuille indiqué.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "income",
                "expense",
                "transfer"
              ]
            },
            "wallet_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "Portefeuille source"
            },
            "amount": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "currency": {
              "type": "string",
              "minLength": 3,
              "maxLength": 3,
              "description": "Code devise ISO, ex: MGA, EUR"
            },
            "occurred_on": {
              "type": "string",
              "description": "Date ISO YYYY-MM-DD"
            },
            "description": {
              "type": "string"
            },
            "to_wallet_id": {
              "description": "Requis pour type=transfer",
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "node_id": {
              "description": "Poste budgétaire",
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "counterparty_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            }
          },
          "required": [
            "type",
            "wallet_id",
            "amount",
            "currency",
            "occurred_on"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
